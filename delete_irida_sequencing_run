delete_irida_sequencing_run() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { echo "usage: ${FUNCNAME[0]} RUN_ID" ; return 1 ; }
    [[ ! "${1%%:*}" =~ ^[0-9]+$ ]] && { echo "invalid run ID: ${1%%:*}" ; return 1 ; }
    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f term --filter border "Reminder: admin credentials required" >&2
    else
        echo "Reminder: admin credentials required" >&2
    fi
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X DELETE "${IRIDA_BASE_URL}/api/sequencingrun/${1%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "sequencing run ${1%%:*} deleted" ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden - admin token required" >&2 ; return 1 ;;
        404) echo "ERROR: sequencing run ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}
complete -F _irida_sequence_run_complete delete_irida_sequencing_run

# NOTE: DELETE /api/sequencingrun/{id} requires admin token.
# Returns 403 as non-admin. Use get_irida_token_admin before calling.
# Confirmed on VIGASP 23.01.3.
