get_irida_project_hash() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID" >&2 ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects/${1%%:*}/hash" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '{project_id: (.resource.links[] | select(.rel == "project") | .href | split("/") | last), hash: .resource.projectHash}' | /usr/bin/mlr --ijson --opprint cat ;;
        403) echo "ERROR: HTTP 403 - access denied" >&2 ; return 1 ;;
        404) echo "ERROR: HTTP 404 - project ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

complete -F _irida_projects_complete get_irida_project_hash

# NOTE: projectHash is a Java integer hash - negative values are valid.
# The hash changes when the project's samples are modified. It does not
# change on project metadata updates alone. Useful as a cheap change
# detection mechanism without fetching all samples.
