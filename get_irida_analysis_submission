get_irida_analysis_submission() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { echo "usage: ${FUNCNAME[0]} ANALYSIS_ID" >&2 ; return 1 ; }
    [[ "${1%%:*}" == "no_analyses_found" ]] && { echo "ERROR: no analyses found for that project" >&2 ; return 1 ; }
    [[ ! "${1%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid analysis ID: ${1%%:*}" >&2 ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/analysisSubmissions/${1%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '{id: .resource.identifier, name: .resource.name, state: .resource.analysisState, cleaned: .resource.analysisCleanedState, priority: .resource.priority, workflow: .resource.workflowId, automated: .resource.automated, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.resource.modifiedDate / 1000 | strftime("%Y-%m-%d"))}' | /usr/bin/mlr --ijson --opprint cat ;;
        403) echo "ERROR: HTTP 403 - access denied" >&2 ; return 1 ;;
        404) echo "ERROR: HTTP 404 - analysis submission ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

# no tab completion - analysis IDs are not enumerable without hitting the slow Galaxy endpoint
complete get_irida_analysis_submission

# NOTE: analysisType is NOT present in this response. It is only available
# via GET /api/analysisSubmissions/{id}/analysis when state=COMPLETED.
# That endpoint blocks synchronously on Galaxy and can take 15-60 minutes to respond.
# It is intentionally excluded from this function to avoid hanging the shell.
# Use get_irida_analysis_result to fetch it when you can afford the wait.
