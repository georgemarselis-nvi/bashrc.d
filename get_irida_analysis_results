# along with this program. If not, see <https://www.gnu.org/licenses/>.
get_irida_analysis_results() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID ANALYSIS_ID (you need the second argument, as well)" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid analysis ID: ${2%%:*}" >&2 ; return 1 ; }
    local _analysis_id="${2%%:*}"
    local _response _http_code _state
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/analysisSubmissions/${_analysis_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) _state=$( echo "${_response}" | /usr/bin/jq -r '.resource.analysisState // "null"' )
             [[ "${_state}" == "null"      ]] && { echo "ERROR: analysis ${_analysis_id} not found" >&2 ; return 1 ; }
             [[ "${_state}" != "COMPLETED" ]] && { echo "ERROR: analysis ${_analysis_id} is ${_state}, not COMPLETED" >&2 ; return 1 ; } ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: analysis ${_analysis_id} not found"      >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/analysisSubmissions/${_analysis_id}/analysis" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200)  echo "${_response}" | /usr/bin/jq '{id: .resource.identifier, analysis_type: .resource.analysisType.type, execution_id: .resource.executionManagerAnalysisId, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), output_files: [.resource.links[] | select(.rel | startswith("outputFile")) | {file: (.rel | ltrimstr("outputFile/")), url: .href}]}' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: analysis ${_analysis_id} has no output"  >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -F _irida_analysis_complete get_irida_analysis_results
