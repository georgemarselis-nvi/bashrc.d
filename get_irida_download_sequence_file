get_irida_download_sequence_file() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID PAIR_ID FILE_ID (missing PROJECT_ID)" >&2 ; return 1 ; }
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID PAIR_ID FILE_ID (missing SAMPLE_ID)" >&2 ; return 1 ; }
    [[ -z "${3}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID PAIR_ID FILE_ID (missing PAIR_ID)" >&2 ; return 1 ; }
    [[ -z "${4}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID PAIR_ID FILE_ID (missing FILE_ID)" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _pair_id="${3%%:*}"
    local _file_id="${4%%:*}"
    local _response _http_code _filename
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/pairs/${_pair_id}/files/${_file_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) _filename=$( echo "${_response}" | /usr/bin/jq -r '.resource.fileName // empty' )
             [[ -z "${_filename}" ]] && { echo "ERROR: fileName missing in response" >&2 ; return 1 ; } ;;
        401) echo "ERROR: unauthorized - token invalid or expired"                              >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                                                            >&2 ; return 1 ;;
        404) echo "ERROR: file ${_file_id} not found in pair ${_pair_id} for sample ${_sample_id}" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"                                          >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"                                        >&2 ; return 1 ;;
    esac
    _http_code=$( /usr/bin/curl --silent --write-out '%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/pairs/${_pair_id}/files/${_file_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H "Accept: application/fastq" -o "${_filename}" )
    case "${_http_code}" in
        200) echo "downloaded: ${_filename}" ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: file ${_file_id} not found"             >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"            >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"          >&2 ; return 1 ;;
    esac
}

# provides project, sample, pair, file ID completions for get_irida_download_sequence_file
_irida_download_complete() {
    check_irida_connectivity || return 1
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  COMPREPLY=($(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.name)"')" -- "${COMP_WORDS[COMP_CWORD]}")) ;;
        2)  local project_id="${COMP_WORDS[1]%%:*}"
            COMPREPLY=($(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${project_id}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.sampleName)"')" -- "${COMP_WORDS[COMP_CWORD]}")) ;;
        3)  local sample_id="${COMP_WORDS[2]%%:*}"
            COMPREPLY=($(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${sample_id}/pairs" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier)"')" -- "${COMP_WORDS[COMP_CWORD]}")) ;;
        4)  local sample_id="${COMP_WORDS[2]%%:*}"
            local pair_id="${COMP_WORDS[3]%%:*}"
            COMPREPLY=($(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${sample_id}/pairs" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r --arg pid "${pair_id}" '.resource.resources[] | select(.identifier == $pid) | .files[] | "\(.identifier):\(.fileName)"')" -- "${COMP_WORDS[COMP_CWORD]}")) ;;
        *)  COMPREPLY=() ;;
    esac
}

complete -F _irida_download_complete get_irida_download_sequence_file
