# get single-end (unpaired) sequence file metadata for a sample. Does not download any files.
#
# PROJECT_ID is used only for tab completion to narrow down samples, not passed to the API
# SAMPLE_ID is the actual argument used in the curl call
# example: get_irida_sample_unpaired_metadata [TAB once for project id] 150:test_gmarselis [TAB for sample id] 1234:some-sample

get_irida_sample_unpaired_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: $0 PROJECT_ID SAMPLE_ID (you need the second argument, as well)" ; return 1 ; }
    /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${2%%:*}/sequenceFiles/unpaired" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .fileName, size: .fileSizeBytes}]' | /usr/bin/mlr --ijson --opprint cat ;
}

complete -F _irida_sample_files_complete_metadata get_irida_sample_unpaired_metadata
