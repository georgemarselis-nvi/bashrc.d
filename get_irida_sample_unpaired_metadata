get_irida_sample_unpaired_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid sample ID: ${2%%:*}" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' \
        -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/unpaired" \
        -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sample ${_sample_id} not found"         >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"            >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"          >&2 ; return 1 ;;
    esac
    [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "sample ${_sample_id} has no unpaired files" ; return 1 ; }
    echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, processingState: .processingState, file_id: .sequenceFile.identifier, name: .sequenceFile.fileName, size: .sequenceFile.fileSizeBytes, sha256: .sequenceFile.uploadSha256, created: (.sequenceFile.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.sequenceFile.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_samples_complete get_irida_sample_unpaired_metadata

# NOTE: /api/samples/{id}/sequenceFiles/unpaired returns 500 on IRIDA 23.01.3 - routing bug,
# Spring servlet tries to parse "unpaired" as a Long fileId (NumberFormatException).
# Using /api/samples/{id}/unpaired directly instead. See issue #4.
# Fields are under .sequenceFile nested object, not directly on the unpaired resource.
# uploadSha256 is computed asynchronously post-upload - null immediately after upload,
# populated within seconds. Confirmed on VIGASP 23.01.3.
