delete_irida_sequence_file() {
    echo "ERROR: DELETE /api/samples/{id}/sequenceFiles/{fileId} is broken on IRIDA 23.01.3." >&2
    echo "       Returns HTTP 500 NullPointerException regardless of file type or token." >&2
    echo "       Use the IRIDA web UI to delete sequence files." >&2
    echo "       See GitHub issue #4 for details." >&2
    return 1
}

# no tab completion - function is not operational
complete delete_irida_sequence_file
