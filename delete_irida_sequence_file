delete_irida_sequence_file() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { /usr/bin/printf "Missing project ID.\nusage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID OBJECT_TYPE OBJECT_ID\n" >&2 ; return 1 ; }
    [[ -z "${2}" ]] && { /usr/bin/printf "Missing sample ID.\nusage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID OBJECT_TYPE OBJECT_ID\n" >&2 ; return 1 ; }
    [[ -z "${3}" ]] && { /usr/bin/printf "Missing OBJECT_TYPE.\nusage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID OBJECT_TYPE OBJECT_ID\n" >&2 ; return 1 ; }
    [[ -z "${4}" ]] && { /usr/bin/printf "Missing OBJECT_ID.\nusage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID OBJECT_TYPE OBJECT_ID\n" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid sample ID: ${2%%:*}" >&2 ; return 1 ; }
    [[ ! "${4%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid object ID: ${4%%:*}" >&2 ; return 1 ; }
    [[ "${3}" != "unpaired" && "${3}" != "pairs" && "${3}" != "fast5" ]] && { echo "ERROR: invalid object type: ${3} (unpaired|pairs|fast5)" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _object_id="${4%%:*}"
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' \
        -X DELETE "${IRIDA_BASE_URL}/api/samples/${_sample_id}/${3}/${_object_id}" \
        -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "sequencing object ${_object_id} (${3}) deleted from sample ${_sample_id}" ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sample ${_sample_id} or object ${_object_id} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error (check object type and object ID - not file ID)" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"          >&2 ; return 1 ;;
    esac
}

complete -F _irida_samples_complete delete_irida_sequence_file
