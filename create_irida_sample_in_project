create_irida_sample_in_project() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID sampleName description organism [isolate] [strain] [collectedBy] [collectionDate] [geographicLocationName] [isolationSource] [latitude] [longitude]" >&2 ; return 1 ; }
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID sampleName description organism (missing sampleName)" >&2 ; return 1 ; }
    [[ -z "${3}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID sampleName description organism (missing description)" >&2 ; return 1 ; }
    [[ -z "${4}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID sampleName description organism (missing organism)" >&2 ; return 1 ; }

    local project_id="${1%%:*}"
    local sampleName="${2}"
    local description="${3}"
    local organism="${4}"
    local isolate="${5}"
    local strain="${6}"
    local collectedBy="${7}"
    local collectionDate="${8}"
    local geographicLocationName="${9}"
    local isolationSource="${10}"
    local latitude="${11}"
    local longitude="${12}"

    local json="{\"sampleName\":\"${sampleName}\",\"description\":\"${description}\",\"organism\":\"${organism}\""
    [[ -n "${isolate}"                ]] && json+=",\"isolate\":\"${isolate}\""
    [[ -n "${strain}"                 ]] && json+=",\"strain\":\"${strain}\""
    [[ -n "${collectedBy}"            ]] && json+=",\"collectedBy\":\"${collectedBy}\""
    [[ -n "${collectionDate}"         ]] && json+=",\"collectionDate\":\"${collectionDate}\""
    [[ -n "${geographicLocationName}" ]] && json+=",\"geographicLocationName\":\"${geographicLocationName}\""
    [[ -n "${isolationSource}"        ]] && json+=",\"isolationSource\":\"${isolationSource}\""
    [[ -n "${latitude}"               ]] && json+=",\"latitude\":\"${latitude}\""
    [[ -n "${longitude}"              ]] && json+=",\"longitude\":\"${longitude}\""
    json+="}"

    local response
    response=$( /usr/bin/curl --silent -X POST "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${project_id}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H "Content-Type: application/json" -d "${json}" ) || { echo "ERROR: curl failed" >&2 ; return 1 ; }
    [[ -z "${response}" ]] && { echo "ERROR: no response from server" >&2 ; return 1 ; }
    echo "${response}" | /usr/bin/jq '[.resource | {id: .identifier, sampleName: .sampleName, organism: .organism, description: .description, isolate: .isolate, strain: .strain, collectedBy: .collectedBy, collectionDate: .collectionDate, geographicLocationName: .geographicLocationName, isolationSource: .isolationSource, latitude: .latitude, longitude: .longitude, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), self: (.links[] | select(.rel == "self") | .href)}]' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_projects_complete create_irida_sample_in_project

# NOTE: optional fields not provided are omitted from the JSON payload entirely.
# IRIDA rejects null strings for typed fields such as collectionDate (expects ISO date or absent).
# use update_irida_sample (PATCH /api/samples/{id}) to set optional fields after creation.
#
# NOTE: IRIDA 23.01.3 rejects null strings for typed fields and returns HTTP 400
# with "JSON parse error: Unparseable date: null" if collectionDate or other typed
# fields are sent as the string "null" rather than omitted. Omit optional fields
# entirely from the payload when not provided.
