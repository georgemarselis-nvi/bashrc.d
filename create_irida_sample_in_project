# create_irida_sample_in_project
# create a new sample in an IRIDA project
#
# usage: create_irida_sample_in_project PROJECT_ID sampleName description organism [isolate] [strain] [collectedBy] [collectionDate] [geographicLocationName] [isolationSource] [latitude] [longitude]
#
# mandatory: PROJECT_ID sampleName description organism
# optional:  isolate strain collectedBy collectionDate geographicLocationName isolationSource latitude longitude
#
# example: create_irida_sample_in_project 154:ZZTEST_API_DO_NOT_USE ZZTEST_SAMPLE_DO_NOT_USE "THIS IS A TEST SAMPLE DELETE ME" "Trollus norvegicus"
#
