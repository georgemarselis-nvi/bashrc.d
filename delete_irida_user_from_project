delete_irida_user_from_project() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { /usr/bin/printf "Missing project ID.\nusage: ${FUNCNAME[0]} PROJECT_ID USERNAME\n" ; return 1 ; }
    [[ -z "${2:-}" ]] && { /usr/bin/printf "Missing username.\nusage: ${FUNCNAME[0]} PROJECT_ID USERNAME\n" ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X DELETE "${IRIDA_BASE_URL}/api/projects/${1%%:*}/users/${2%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    case "${_http_code}" in
        200) echo "user ${2%%:*} removed from project ${1%%:*}" ;;
        403) echo "ERROR: forbidden - not a member of project ${1%%:*}" >&2 ; return 1 ;;
        404) echo "ERROR: user ${2%%:*} or project ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

# tab completion for delete_irida_user_from_project: PROJECT_ID (arg 1), USERNAME from project members (arg 2)
_irida_delete_user_from_project_complete() {
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  COMPREPLY=( $(compgen -W "$(/usr/bin/curl --silent -X GET "${IRIDA_BASE_URL}/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.name | gsub(" "; "_"))"')" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        2)  local project_id="${COMP_WORDS[1]%%:*}"
            local IFS=$'\n'
            mapfile -t COMPREPLY < <(compgen -W "$(/usr/bin/curl --silent -X GET "${IRIDA_BASE_URL}/api/projects/${project_id}/users" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.username):\(.firstName | gsub(" "; "_"))_\(.lastName | gsub(" "; "_"))"')" -- "${COMP_WORDS[COMP_CWORD]}") ;;
        *)  COMPREPLY=() ;;
    esac
}

complete -o nosort -F _irida_delete_user_from_project_complete delete_irida_user_from_project
