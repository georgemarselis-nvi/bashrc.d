get_irida_sample_fast5_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid sample ID: ${2%%:*}" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/fast5" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "sample ${_sample_id} has no fast5 files" ; return 1 ; }
             echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, processingState: .processingState, fast5Type: .fast5Type, file_id: .file.identifier, name: .file.fileName, size: .file.fileSizeBytes, sha256: .file.uploadSha256, created: (.file.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.file.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sample ${_sample_id} not found"          >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -F _irida_samples_complete get_irida_sample_fast5_metadata
# NOTE: /api/samples/{id}/sequenceFiles/fast5 returns 500 on IRIDA 23.01.3 - routing bug,
# Spring servlet tries to parse "fast5" as a Long fileId (NumberFormatException).
# Using /api/samples/{id}/fast5 directly instead. See issue #4.
# Fields are under .file nested object, not directly on the fast5 resource.
# uploadSha256 is computed asynchronously post-upload. See issue #12.
