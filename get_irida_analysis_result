get_irida_analysis_result() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} ANALYSIS_ID" >&2 ; return 1 ; }
    [[ "${1%%:*}" == "no_analyses_found" ]] && { echo "ERROR: no analyses found for that project" >&2 ; return 1 ; }
    [[ ! "${1%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid analysis ID: ${1%%:*}" >&2 ; return 1 ; }
    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f term --filter border "WARNING: this endpoint queries Galaxy. expect 15-60 minutes." >&2
    else
        echo "WARNING: this endpoint queries Galaxy. expect 15-60 minutes." >&2
    fi
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/analysisSubmissions/${1%%:*}/analysis" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '{id: .resource.identifier, analysis_type: .resource.analysisType.type, execution_id: .resource.executionManagerAnalysisId, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), output_files: [.resource.links[] | select(.rel | startswith("outputFile/")) | {file: .rel, href: .href}]}' | /usr/bin/mlr --ijson --opprint cat ;;
        403) echo "ERROR: HTTP 403 - access denied" >&2 ; return 1 ;;
        404) echo "ERROR: HTTP 404 - analysis submission ${1%%:*} not found or not completed" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

# no tab completion - analysis IDs are not enumerable without hitting the slow Galaxy endpoint
complete get_irida_analysis_result

# NOTE: this endpoint queries Galaxy synchronously. IRIDA holds the HTTP connection
# open while making sequential Galaxy API calls for each analysis. With large analysis
# histories this can take 15-60 minutes. If the function hangs, Galaxy is not responding
# to IRIDA. Kill with Ctrl+C. See issue #8.
# Only available when analysisState=COMPLETED.
