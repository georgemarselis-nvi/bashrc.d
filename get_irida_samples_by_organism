# get_irida_samples_by_organism
# cross-project sample count grouped by organism string
# exposes inconsistent organism naming across projects
#
# usage: get_irida_samples_by_organism --sort-by-samples | --sort-by-organism [--group]
#        --group: aggregate by organism, show project count and total samples
#
# example: get_irida_samples_by_organism --sort-by-samples
#          get_irida_samples_by_organism --sort-by-organism
#          get_irida_samples_by_organism --sort-by-organism --group
#          get_irida_samples_by_organism --sort-by-samples --group
