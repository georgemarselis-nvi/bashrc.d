# get all projects the current user has access to, displayed as a table
# no arguments needed, no tabbing
# provides the autocompletion for other get_irida_ functions
#
# example: get_irida_projects

get_irida_projects() {
    check_irida_connectivity || { echo "IRIDA unreachable" ; return 1 ; }
    /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, description: .projectDescription}]' | /usr/bin/mlr --ijson --opprint cat ; 
}
