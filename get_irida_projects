get_irida_projects() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, organism: .organism, description: .projectDescription, genome_size: .genomeSize, min_coverage: .minimumCoverage, max_coverage: .maximumCoverage}]' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden - insufficient permissions" >&2 ; return 1 ;;
        404) echo "ERROR: not found - check IRIDA base URL" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

# disable tab completion as a hint we do not need arguments here
complete get_irida_projects
