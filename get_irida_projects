get_irida_projects() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, description: .projectDescription}]' | /usr/bin/mlr --ijson --opprint cat ; 
}

# disable tab completion as a hint we do not need arguments here
complete get_irida_projects
