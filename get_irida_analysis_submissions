get_irida_analysis_submissions() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1

    local _cache="${HOME}/.bashrc.d/test_output/analysisSubmissions.md"
    [[ ! -f "${_cache}" ]] && { echo "ERROR: cache file not found: ${_cache}" >&2 ; return 1 ; }

    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f mono12 --filter border "WARNING" >&2
    fi
    echo    "  GET /api/analysisSubmissions queries Galaxy for EVERY submission." >&2
    echo    "  On VIGASP 23.01.3 this will hang for 15-60 MINUTES." >&2
    echo    "  DO NOT RUN THIS AGAINST LIVE VIGASP." >&2
    echo    "  Serving cached result in:" >&2

    for _i in $(seq 15 -1 1); do
        printf "\r  %2d ... " "${_i}" >&2
        sleep 1
    done
    printf "\r         \r" >&2
    echo "" >&2

    /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, label: .label, workflowId: .workflowId, remoteWorkflowId: .remoteWorkflowId, state: .analysisState, cleaned: .analysisCleanedState, priority: .priority, automated: .automated, updateSamples: .updateSamples, analysisDescription: .analysisDescription, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), self: (.links[] | select(.rel == "self") | .href)}]' < "${_cache}" | /usr/bin/mlr --ijson --opprint cat

    echo "" >&2
    echo "" >&2

    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f standard --filter gay --filter border "CACHED RESULT NOT LIVE DATA" >&2
    else
        echo "*** CACHED RESULT -- NOT LIVE DATA ***" >&2
    fi

    # Dead code: curl call preserved for when IRIDA is fixed or replaced.
    #
    #  If you want to test this, uncomment and go grab some coffee
    #
