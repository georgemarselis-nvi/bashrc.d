get_irida_user_projects() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} USERNAME" >&2 ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/users/${1%%:*}/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.projectResources.resources | length' ) -eq 0 ]] && { echo "user ${1%%:*} is not a member of any projects" ; return 0 ; }
             echo "${_response}" | /usr/bin/jq '[.projectResources.resources[] | {id: .identifier, name: .name, organism: .organism, description: .projectDescription, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat ;;
        403) echo "ERROR: HTTP 403 - access denied" >&2 ; return 1 ;;
        404) echo "ERROR: HTTP 404 - user ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

complete -o nosort -F _irida_users_complete get_irida_user_projects

# NOTE: response structure is projectResources.resources, not resource.resources
# as used by all other IRIDA API endpoints. Inconsistency in the IRIDA API.
