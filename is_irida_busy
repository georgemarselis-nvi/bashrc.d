# is_irida_busy
# check if IRIDA has any running or queued analyses
#
# Returns 0 (true) if IRIDA is busy (running > 0 or queued > 0)
# Returns 1 (false) if IRIDA is idle
# Returns 2 on error
#
# usage: is_irida_busy
#
# example: is_irida_busy && echo "busy, wait" || echo "idle, go"
