# mod_irida_sample
# update fields on an existing IRIDA sample via PATCH /api/samples/{id}
# confirmed working as non-admin on VIGASP 23.01.3 - RBAC gap, see GitHub issue #12
#
# usage: mod_irida_sample PROJECT_ID SAMPLE_ID [--name NAME] [--description DESC] [--organism ORG]
#                         [--isolate ISOLATE] [--strain STRAIN] [--collected-by COLLECTED_BY]
#                         [--collection-date DATE] [--location LOCATION] [--isolation-source SOURCE]
#                         [--latitude LAT] [--longitude LON]
#
# at least one optional field must be provided
#
# example: mod_irida_sample 150:test_gmarselis 11745:ZZTEST_SAMPLE_DO_NOT_USE --description "new description"
#
# NOTE: PATCH /api/samples/{id} response links reveal that sample/sequenceFiles/pairs
# resolves to /api/samples/{id}/pairs - confirming the undocumented paired upload endpoint.
#
