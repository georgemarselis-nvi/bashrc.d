get_irida_stale_projects() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local _since_days=30 _http_code _response _tmp _spin_pid
    local _spinner=( '|' '/' '-' '\\' )

    _spin() { local i=0 ; while true ; do printf '\rplease wait, getting projects: %s ' "${_spinner[$((i++ % 4))]}" >&2 ; sleep 0.1 ; done ; }

    for _arg in "$@"; do
        case "${_arg}" in
            --since-days) : ;;
            [0-9]*) _since_days="${_arg}" ;;
            *) echo "ERROR: unknown argument: ${_arg}" >&2 ; return 1 ;;
        esac
    done

    local _now_ms=$(( $(date +%s) * 1000 ))
    local _cutoff_ms=$(( ( $(date +%s) - (_since_days * 86400) ) * 1000 ))

    _tmp=$( mktemp )
    _spin & _spin_pid=$!
    /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" > "${_tmp}"
    kill "${_spin_pid}" 2>/dev/null ; wait "${_spin_pid}" 2>/dev/null ; printf '\r\033[K' >&2
    _http_code=$( /usr/bin/tail -1 "${_tmp}" )
    _response=$( /usr/bin/sed '$d' "${_tmp}" )
    rm -f "${_tmp}"
    case "${_http_code}" in
        200) ;;
        401) echo "ERROR: HTTP 401 - unauthorized" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac

    local _rows="" _pid _pname _proj_response _proj_http _tmp2 _count _max_created _days _years _rem_days _stale_str
    local _projects=$( echo "${_response}" | /usr/bin/jq -r '.resource.resources[] | [.identifier, .name] | @tsv' )
    while IFS=$'\t' read -r _pid _pname; do
        _tmp2=$( mktemp )
        _spin & _spin_pid=$!
        /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects/${_pid}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" > "${_tmp2}"
        kill "${_spin_pid}" 2>/dev/null ; wait "${_spin_pid}" 2>/dev/null ; printf '\r\033[K' >&2
        _proj_http=$( /usr/bin/tail -1 "${_tmp2}" )
        _proj_response=$( /usr/bin/sed '$d' "${_tmp2}" )
        rm -f "${_tmp2}"
        if [[ "${_proj_http}" == "200" ]]; then
            _count=$( echo "${_proj_response}" | /usr/bin/jq '.resource.resources | length' )
            _max_created=$( echo "${_proj_response}" | /usr/bin/jq -r '[.resource.resources[].createdDate] | max // 0' )
            if [[ "${_count}" -gt 0 && "${_max_created}" -lt "${_cutoff_ms}" ]]; then
                _days=$(( (_now_ms - _max_created) / 1000 / 86400 ))
                _years=$(( _days / 365 ))
                _rem_days=$(( _days % 365 ))
                if [[ "${_years}" -gt 0 ]]; then
                    _stale_str="${_days} days (${_years} year(s) ${_rem_days} days)"
                else
                    _stale_str="${_days} days"
                fi
                _rows+=$( printf '%s\t%s\t%s\t%s\t%s\n' "${_pid}" "${_pname}" "${_count}" "${_days}" "${_stale_str}" )
                _rows+=$'\n'
            fi
        fi
    done <<< "${_projects}"

    [[ -z "${_rows}" ]] && { echo "no stale projects found in the last ${_since_days} days" ; return 0 ; }
    printf '%s' "${_rows}" | /usr/bin/mlr --itsv --opprint label id,project,samples,days_stale,stale_for then put '$id = int($id); $days_stale = int($days_stale)' then sort -n days_stale then cut -f id,project,samples,stale_for
}

_get_irida_stale_projects_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( $(compgen -W '--since-days' -- "${cur}") )
}

complete -F _get_irida_stale_projects_complete get_irida_stale_projects
