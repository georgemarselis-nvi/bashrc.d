# get_irida_stale_projects
# list projects with no uploads in the last N days
# shows how long each project has been stale
#
# usage: get_irida_stale_projects [--since-days N]
#        default: 30 days
#
# example: get_irida_stale_projects
#          get_irida_stale_projects --since-days 7
#
