#
# provides project then analysis ID completions for get_irida_analysis_results
_irida_analysis_complete() {
    check_irida_connectivity || return 1
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  local IFS=$'\n'
            mapfile -t COMPREPLY < <(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.name | gsub(" "; "_"))"')" -- "${COMP_WORDS[COMP_CWORD]}") ;;
        2)  local project_id="${COMP_WORDS[1]%%:*}"
            local analyses
            analyses=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${project_id}/analyses" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.name | gsub(" "; "_"))"' 2>/dev/null )
            if [[ -z "${analyses}" ]]; then
                COMPREPLY=()
            else
                mapfile -t COMPREPLY < <(compgen -W "${analyses}" -- "${COMP_WORDS[COMP_CWORD]}")
            fi ;;
        *)  COMPREPLY=() ;;
    esac
}

