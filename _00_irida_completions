#
# provides project then sample ID completions for functions that need both
_irida_samples_complete() {
    check_irida_connectivity || return 1
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  COMPREPLY=($(compgen -W "$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.name)"')" -- "${COMP_WORDS[COMP_CWORD]}")) ;;
        2)  local project_id="${COMP_WORDS[1]%%:*}"
            local samples
            samples=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${project_id}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.sampleName)"' 2>/dev/null )
            if [[ -z "${samples}" ]]; then
                COMPREPLY=( $(compgen -W "no_samples_found" -- "${COMP_WORDS[COMP_CWORD]}") )
            else
                COMPREPLY=($(compgen -W "${samples}" -- "${COMP_WORDS[COMP_CWORD]}"))
            fi ;;
        *)  COMPREPLY=() ;;
    esac
}

