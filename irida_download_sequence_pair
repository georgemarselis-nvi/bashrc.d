# download both R1 and R2 files for a paired-end sample in one call
# PROJECT_ID is used only for tab completion, not passed to the API
# SAMPLE_ID and PAIR_ID are used in the curl call
#
# example: irida_download_sequence_pair [TAB for project] 2:Test_Data_Uploading [TAB for sample] 3:sample-1-Added [TAB for pair] 3

irida_download_sequence_pair() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local sample_id="${2%%:*}"
    local pair_id="${3%%:*}"
    local file_ids
    file_ids=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${sample_id}/sequenceFiles/pairs" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r --arg pid "${pair_id}" '.resource.resources[] | select(.identifier == $pid) | .files[].identifier' )
    for file_id in ${file_ids}; do
        irida_download_sequence_file "${1}" "${2}" "${pair_id}" "${file_id}"
    done
}

complete -F _irida_download_pair_complete irida_download_sequence_pair
