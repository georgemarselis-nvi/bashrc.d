get_irida_project() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID" ; return 1 ; }
    local response
    response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${1%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    [[ -z "${response}" ]] && { echo "project ${1%%:*} not found" ; return 1 ; }
    echo "${response}" | /usr/bin/jq '{id: .resource.identifier, name: .resource.name, description: .resource.projectDescription, organism: .resource.organism, genome_size: .resource.genomeSize, min_coverage: .resource.minimumCoverage, max_coverage: .resource.maximumCoverage, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.resource.modifiedDate / 1000 | strftime("%Y-%m-%d"))}' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_projects_complete get_irida_project
