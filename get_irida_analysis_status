# along with this program. If not, see <https://www.gnu.org/licenses/>.
get_irida_analysis_status() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2:-}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID ANALYSIS_ID (you need the second argument, as well)" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid analysis ID: ${2%%:*}" >&2 ; return 1 ; }
    local _analysis_id="${2%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/analysisSubmissions/${_analysis_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '{id: .resource.identifier, name: .resource.label, state: .resource.analysisState, cleaned: .resource.analysisCleanedState, priority: .resource.priority, workflow: .resource.workflowId, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.resource.modifiedDate / 1000 | strftime("%Y-%m-%d"))}' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: analysis ${_analysis_id} not found"      >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -F _irida_analysis_complete get_irida_analysis_status
# NOTE: in the results, "CLEANED" means Galaxy has cleaned up the working files for that analysis run - intermediate files, job directories,
# temporary data and that the execution environment has been tidied up after the job finished (or errored). It is separate from the analysis state itself.
# CREATED and MODIFIED are milliseconds from epoch.
