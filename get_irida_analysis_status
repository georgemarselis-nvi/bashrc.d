# get the state of an analysis submission
# PROJECT_ID is used only for tab completion, not passed to the API
# ANALYSIS_ID is the actual argument used in the curl call
#
# NOTE: tab completion shows all analysis submissions regardless of state.
# Only completed analyses with output will return results from get_irida_analysis_results.
#
# example: get_irida_analysis_status [TAB for project id] 13:Slush [TAB for analysis id] 42215:Assembly_QC__2-3-2025

get_irida_analysis_status() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID ANALYSIS_ID (you need the second argument, as well)" ; return 1 ; }
    local response
    response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/analysisSubmissions/${2%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    [[ -z "${response}" ]] && { echo "analysis ${2%%:*} not found" ; return 1 ; }
    echo "${response}" | /usr/bin/jq '{id: .resource.identifier, name: .resource.label, state: .resource.analysisState, cleaned: .resource.analysisCleanedState, created: .resource.createdDate, modified: .resource.modifiedDate}' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_analysis_complete get_irida_analysis_status
