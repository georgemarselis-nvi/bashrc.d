# delete_irida_user
# delete an IRIDA user account permanently
# requires admin token - use get_irida_token_admin first
#
# usage: delete_irida_user USERNAME [--confirm]
#
# --confirm: skip the confirmation prompt and countdown
#
# example: delete_irida_user kotopoulos
# example: delete_irida_user kotopoulos --confirm
#
# NOTE: DELETE /api/users/ only accepts numeric IDs, not usernames.
# Function resolves username to ID via GET /api/users/{username} before
# deletion.
