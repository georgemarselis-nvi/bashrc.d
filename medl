medl() { [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} <file>" >&2 ; return 1 ; } ; git show "HEAD:${1}" > "/tmp/${1##*/}.old" && /usr/bin/meld "/tmp/${1##*/}.old" "${1}" ; /usr/bin/rm -f "/tmp/${1##*/}.old" ; }

_medl_complete() {
    local cur ; cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( $( compgen -W "$( /usr/bin/git ls-files 2>/dev/null )" -- "${cur}" ) )
}

complete -F _medl_complete medl
