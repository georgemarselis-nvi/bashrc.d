# get_irida_sequence_run
# get sequencing run(s) from IRIDA
#
# examples:
#   get_irida_sequence_run
#   get_irida_sequence_run 42
#   get_irida_sequence_run --sort-id
#   get_irida_sequence_run --sort-created
#   get_irida_sequence_run --group-status
#
# NOTE: non-admin users will only see sequencing runs they created.
#       admin users see all runs. Use get_irida_token_admin to see all runs.
