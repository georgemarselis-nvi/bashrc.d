get_irida_sequence_run() {
    local _id=""
    local _sort=""
    for _arg in "$@"; do
        [[ "${_arg}" == "--sort-id"      ]] && _sort="sort -nr id"          && continue
        [[ "${_arg}" == "--group-status" ]] && _sort="sort -f uploadStatus" && continue
        [[ "${_arg%%:*}" =~ ^[0-9]+$    ]] && _id="${_arg%%:*}"
    done
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local _response _http_code _mlr_cmd
    [[ -n "${_sort}" ]] && _mlr_cmd="${_sort}" || _mlr_cmd="cat"
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/sequencingrun/${_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H "Accept: application/json" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sequencing run ${_id} not found"        >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"            >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"          >&2 ; return 1 ;;
    esac
    if [[ -n "${_id}" ]]; then
        [[ $( echo "${_response}" | /usr/bin/jq -r '.resource.identifier // "null"' ) == "null" ]] && { echo "sequencing run ${_id} not found" >&2 ; return 1 ; }
        echo "${_response}" | /usr/bin/jq '[.resource | {id: (.identifier | tonumber), label: .label, sequencerType: .sequencerType, uploadStatus: .uploadStatus, layoutType: .layoutType, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), workflow: .workflow, description: .description}]' | eval "/usr/bin/mlr --ijson --opprint ${_mlr_cmd}"
    else
        [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "no sequencing runs" >&2 ; return 1 ; }
        echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: (.identifier | tonumber), label: .label, sequencerType: .sequencerType, uploadStatus: .uploadStatus, layoutType: .layoutType, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), workflow: .workflow, description: .description}]' | eval "/usr/bin/mlr --ijson --opprint ${_mlr_cmd}"
    fi
}

# tab complete the sequencing run identifier:label
complete -F _irida_sequence_run_complete get_irida_sequence_run
