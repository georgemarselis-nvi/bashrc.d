get_irida_sequence_run() {
    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f mono12 --filter border "WARNING" >&2
    fi
    local _id=""
    local _skip_countdown=0
    local _sort=""
    for _arg in "$@"; do
        [[ "${_arg}" == "--skip-countdown" ]] && _skip_countdown=1             && continue
        [[ "${_arg}" == "--sort-id"        ]] && _sort="sort -nr id"           && continue
        [[ "${_arg}" == "--sort-created"   ]] && _sort="sort -nr created"      && continue
        [[ "${_arg}" == "--group-status"   ]] && _sort="sort -f uploadStatus"  && continue
        [[ "${_arg%%:*}" =~ ^[0-9]+$       ]] && _id="${_arg%%:*}"
    done
    if [[ "${_skip_countdown}" -eq 0 ]]; then
        echo "  You need to have run get_irida_token_admin before running this function." >&2
        echo "  If you did not, you will get back an empty json response." >&2
        echo "  You have 15 seconds to abort:" >&2
        echo "" >&2
        for _i in $(seq 15 -1 1); do
            printf "\r  %2d ... " "${_i}" >&2
            sleep 1
        done
        printf "\r         \r" >&2
        echo "" >&2
    fi
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local response
    response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/sequencingrun/${_id%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H "Accept: application/json" )
    local _jq_filter
    local _mlr_cmd
    [[ -n "${_sort}" ]] && _mlr_cmd="${_sort}" || _mlr_cmd="cat"
    if [[ -n "${_id}" ]]; then
        [[ $( echo "${response}" | /usr/bin/jq -r '.resource.identifier // "null"' ) == "null" ]] && { echo "sequencing run ${_id} not found" ; return 1 ; }
        echo "${response}" | /usr/bin/jq '[.resource | {id: (.identifier | tonumber), label: .label, sequencerType: .sequencerType, uploadStatus: .uploadStatus, layoutType: .layoutType, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), workflow: .workflow, description: .description}]' | eval "/usr/bin/mlr --ijson --opprint ${_mlr_cmd}"
    else
        [[ $( echo "${response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "no sequencing runs" ; return 1 ; }
        echo "${response}" | /usr/bin/jq '[.resource.resources[] | {id: (.identifier | tonumber), label: .label, sequencerType: .sequencerType, uploadStatus: .uploadStatus, layoutType: .layoutType, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), workflow: .workflow, description: .description}]' | eval "/usr/bin/mlr --ijson --opprint ${_mlr_cmd}"
    fi
}
# tab complete the sequencing run identifier:label
complete -F _irida_sequence_run_complete get_irida_sequence_run
