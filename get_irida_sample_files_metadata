get_irida_sample_files_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID (you need the second argument, as well)" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid sample ID: ${2%%:*}" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/samples/${_sample_id}/sequenceFiles" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "sample ${_sample_id} has no sequence files" ; return 1 ; }
             echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .fileName, label: .label, sizeMB: (.fileSizeBytes / 1048576 | floor), sha256: .uploadSha256, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sample ${_sample_id} not found"          >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -F _irida_samples_complete get_irida_sample_files_metadata
# NOTE: /api/samples/{id}/sequenceFiles returns both paired and unpaired files but does not
# surface the pair identifier. To get the pair_id needed for get_irida_download_sequence_file,
# call get_irida_sample_pairs_metadata separately.
#
# NOTE: sizeMB is calculated as fileSizeBytes / 1048576 | floor. Files smaller than 1MB
# will show sizeMB as 0. Use get_irida_sample_files_metadata for byte-level accuracy if needed,
# or check fileSizeBytes directly via the raw API response.
