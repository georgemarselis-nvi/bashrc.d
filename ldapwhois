ldapwhois() {
    local user="$1"
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} viXXXX@vet..." ; return 1 ; }

    # Ensure user input format
    [[ "$user" != *@* ]] && user="${user}@vetinst.no"

    # Extract viXXXX part for klist check
    local principal="${user%@*}@vetinst.no"

    # Check for valid Kerberos ticket
    if ! klist -s; then
        echo "No valid Kerberos ticket found. Please enter your password."
        read -s -p "Enter password: " password
        echo
        echo "$password" | kinit "$principal"
        if [[ $? -ne 0 ]]; then
            echo "Kerberos authentication failed."
            return 1
        fi
    fi

    # Perform LDAP search
    ldapsearch -LLL -Q -H ldap://dc02.vetinst.no:3268 -Y GSSAPI -b dc=vetinst,dc=no "(&(objectClass=user)(userPrincipalName=${user}))" displayName
}

_ldapwhois_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( $(compgen -W "$(ldapsearch -LLL -Q -H ldap://dc02.vetinst.no:3268 -Y GSSAPI -b dc=vetinst,dc=no "(&(objectClass=user)(userPrincipalName=${cur}*))" userPrincipalName 2>/dev/null | grep '^userPrincipalName:' | awk '{print $2}')" -- "${cur}") )
}

complete -F _ldapwhois_complete ldapwhois
