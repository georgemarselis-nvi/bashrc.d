get_irida_sample_assemblies_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID (you need the second argument, as well)" ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "invalid sample ID: ${2%%:*}" ; return 1 ; }
    local response
    response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${2%%:*}/assemblies" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    [[ -z "${response}" ]] && { echo "sample ${2%%:*} not found" ; return 1 ; }
    [[ $( echo "${response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "sample ${2%%:*} has no assemblies" ; return 1 ; }
    echo "${response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .fileName, label: .label, size: .fileSizeBytes, revision: .fileRevisionNumber, path: .file, created: (.createdDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_samples_complete get_irida_sample_assemblies_metadata
