get_irida_users() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    if [[ -n "$1" ]]; then
        /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users/${1}/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.projectResources.resources[] | {id: .identifier, name: .name, organism: .organism, description: .projectDescription}]' | /usr/bin/mlr --ijson --opprint cat
    else
        /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, username: .username, name: .label, role: .systemRole, enabled: .enabled, email: .email}]' | /usr/bin/mlr --ijson --opprint cat
    fi
}

_get_irida_users_complete() {
    check_irida_connectivity 2>/dev/null || return
    check_irida_token        2>/dev/null || return
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local usernames
    usernames=$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[].username')
    COMPREPLY=( $(compgen -W "${usernames}" -- "${cur}") )
}
complete -F _get_irida_users_complete get_irida_users
