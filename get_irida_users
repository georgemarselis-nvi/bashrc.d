get_irida_users() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1

    if [[ -n "$1" ]]; then
        local http_code
        http_code=$( /usr/bin/curl --silent -o /dev/null -w "%{http_code}" -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users/${1}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
        [[ "${http_code}" == "500" || "${http_code}" == "404" ]] && { echo "user ${1} not found" ; return 1 ; }
        local response
        response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users/${1}/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
        echo "${response}" | /usr/bin/jq '[.projectResources.resources[] | {id: .identifier, name: .name, label: .label, organism: .organism, description: .projectDescription, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d")), genome_size: .genomeSize, min_coverage: .minimumCoverage, max_coverage: .maximumCoverage, sync_frequency: .syncFrequency, url: .links[0].href}]' | /usr/bin/mlr --ijson --opprint cat
        return
    fi

    local users_json
    users_json=$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users" -H "Authorization: Bearer ${IRIDA_TOKEN}")
    sleep 1

    local usernames
    usernames=$(echo "${users_json}" | /usr/bin/jq -r '.resource.resources[].username')
    local total
    total=$(echo "${usernames}" | wc -l)

    local spinner='|/-\'
    local spin_i=0
    local results=()
    local count=0

    while IFS= read -r username; do
        count=$(( count + 1 ))
        printf "\r  fetching projects for users... %s  (%d/%d)" "${spinner:$(( spin_i % 4 )):1}" "${count}" "${total}" >&2
        spin_i=$(( spin_i + 1 ))

        local http_code
        http_code=$( /usr/bin/curl --silent -o /dev/null -w "%{http_code}" -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users/${username}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
        [[ "${http_code}" == "500" || "${http_code}" == "404" ]] && { echo "user ${username} not found" ; return 1 ; }

        local user_info
        user_info=$(echo "${users_json}" | /usr/bin/jq -r --arg u "${username}" '.resource.resources[] | select(.username == $u) | [.identifier, .username, .firstName, .lastName, .email, .phoneNumber, .systemRole, (.enabled | tostring), .locale, .label, (.createdDate / 1000 | strftime("%Y-%m-%d")), (.modifiedDate / 1000 | strftime("%Y-%m-%d"))] | @tsv')

        local projects
        projects=$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users/${username}/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '[.projectResources.resources[].name] | join(", ")')
        sleep 1

        results+=( "${user_info}"$'\t'"${projects}" )
    done <<< "${usernames}"

    printf "\r%*s\r" 60 "" >&2

    printf '%s\n' "${results[@]}" | /usr/bin/mlr --implicit-csv-header --ifs tab --opprint label id,username,firstname,lastname,email,phone,role,enabled,locale,label,created,modified,projects

}

_get_irida_users_complete() {
    check_irida_connectivity 2>/dev/null || return
    check_irida_token        2>/dev/null || return
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local usernames
    usernames=$(/usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/users" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq -r '.resource.resources[].username')
    COMPREPLY=( $(compgen -W "${usernames}" -- "${cur}") )
}

complete -F _get_irida_users_complete get_irida_users

# NOTE: IRIDA returns HTTP 500 instead of 404 for unknown usernames (UsernameNotFoundException).
# The http_code check treats both 404 and 500 as "user not found" as a workaround.
# See issue #4.
