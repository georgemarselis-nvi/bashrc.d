# change_irida_sequencing_run
# update fields on an existing sequencing run via PATCH /api/sequencingrun/{id}
# confirmed working as non-admin on VIGASP 23.01.3
#
# patchable fields: uploadStatus, description, layoutType, sequencerType
# workflow is NOT patchable - it has no matching field on the SequencingRun bean
#
# example: change_irida_sequencing_run [TAB for run id] 801:SequencingRun_2026-04-06 UPLOADING
