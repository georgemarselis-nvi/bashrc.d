change_irida_sequencing_run() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { /usr/bin/printf "Missing run ID.\nusage: ${FUNCNAME[0]} RUN_ID UPLOAD_STATUS [SEQUENCER_TYPE] [LAYOUT_TYPE] [DESCRIPTION]\n" ; return 1 ; }
    [[ ! "${1%%:*}" =~ ^[0-9]+$ ]] && { echo "invalid run ID: ${1%%:*}" ; return 1 ; }
    [[ -z "${2}" ]] && { /usr/bin/printf "Missing uploadStatus.\nusage: ${FUNCNAME[0]} RUN_ID UPLOAD_STATUS [SEQUENCER_TYPE] [LAYOUT_TYPE] [DESCRIPTION]\n" ; return 1 ; }
    [[ "${2}" != "UPLOADING" && "${2}" != "COMPLETE" && "${2}" != "ERROR" ]] && { echo "invalid uploadStatus: ${2} (UPLOADING|COMPLETE|ERROR)" ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X PATCH "${IRIDA_BASE_URL}/api/sequencingrun/${1%%:*}" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H 'Content-Type: application/json' -d "$( /usr/bin/jq -cn --arg us "${2}" --arg st "${3:-}" --arg lt "${4:-}" --arg desc "${5:-}" '{"uploadStatus": $us} | if $st != "" then . + {"sequencerType": $st} else . end | if $lt != "" then . + {"layoutType": $lt} else . end | if $desc != "" then . + {"description": $desc} else . end' )" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "sequencing run ${1%%:*} updated" ;;
        400) echo "ERROR: bad request - $(echo "${_response}" | /usr/bin/jq -r '.message')" >&2 ; return 1 ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden" >&2 ; return 1 ;;
        404) echo "ERROR: sequencing run ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

#
# tab completion for change_irida_sequencing_run: run id, uploadStatus, sequencerType, layoutType, description
_irida_change_sequence_run_complete() {
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  COMPREPLY=( $(compgen -W "$(/usr/bin/curl --silent -X GET "${IRIDA_BASE_URL}/api/sequencingrun/" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H 'Accept: application/json' | /usr/bin/jq -r '.resource.resources[] | "\(.identifier):\(.label | gsub(" "; "_"))"')" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        2)  COMPREPLY=( $(compgen -W "UPLOADING COMPLETE ERROR" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        3)  COMPREPLY=( $(compgen -W "directory miseq nextseq miniseq iseq nextseq2k" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        4)  COMPREPLY=( $(compgen -W "PAIRED_END SINGLE_END" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        5)  COMPREPLY=( '""' ) ;;
        *)  COMPREPLY=() ;;
    esac
}

complete -F _irida_change_sequence_run_complete change_irida_sequencing_run

# NOTE: workflow is not patchable on SequencingRun - Bean property 'workflow' has no
# matching field (InvalidPropertyException). Confirmed on VIGASP 23.01.3.
# Patchable fields: uploadStatus, sequencerType, layoutType, description.
