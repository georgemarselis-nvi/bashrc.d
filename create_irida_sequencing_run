create_irida_sequencing_run() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { /usr/bin/printf "Missing sequencer type.\nusage: ${FUNCNAME[0]} SEQUENCER_TYPE LAYOUT_TYPE [DESCRIPTION] [WORKFLOW]\n" ; return 1 ; }
    [[ -z "${2}" ]] && { /usr/bin/printf "Missing layout type.\nusage: ${FUNCNAME[0]} SEQUENCER_TYPE LAYOUT_TYPE [DESCRIPTION] [WORKFLOW]\n" ; return 1 ; }
    [[ "${2}" != "PAIRED_END" && "${2}" != "SINGLE_END" ]] && { echo "invalid layoutType: ${2} (PAIRED_END|SINGLE_END)" ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X POST "${IRIDA_BASE_URL}/api/sequencingrun" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H 'Content-Type: application/json' -d "$( /usr/bin/jq -cn --arg st "${1}" --arg lt "${2}" --arg desc "${3:-}" --arg wf "${4:-}" '{"sequencerType": $st, "layoutType": $lt, "description": $desc, "workflow": $wf}' )" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        201) echo "${_response}" | /usr/bin/jq '{id: (.resource.identifier | tonumber), sequencerType: .resource.sequencerType, uploadStatus: .resource.uploadStatus, layoutType: .resource.layoutType, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.resource.modifiedDate / 1000 | strftime("%Y-%m-%d")), workflow: .resource.workflow, description: .resource.description}' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden - insufficient permissions" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

#
# tab completion for create_irida_sequencing_run LAYOUT_TYPE (arg 2)
_irida_layout_type_complete() {
    # sequencerType is a free-form string. Only "miseq" and "directory" are confirmed
    # in IRIDA 23.01.3 documentation. The remaining values are offered as hints based
    # on irida-uploader parser names but are unverified against the API.
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        1)  COMPREPLY=( $(compgen -W "miseq nextseq miniseq iseq nextseq2k directory" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        2)  COMPREPLY=( $(compgen -W "PAIRED_END SINGLE_END" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        3)  COMPREPLY=( $(compgen -W '\"description\"' -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        4)  COMPREPLY=( $(compgen -W '"workflow"' -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        *)  COMPREPLY=() ;;
    esac
}


complete -F _irida_layout_type_complete create_irida_sequencing_run

# NOTE: sequencerType is a free-form string. IRIDA enforces no enum server-side.
# Known values used by irida-uploader: miseq, nextseq, miniseq, iseq, nextseq2k.
# layoutType is the only constrained field: PAIRED_END or SINGLE_END.
# POST /api/sequencingrun confirmed working as non-admin on VIGASP 23.01.3.
# uploadStatus is set to UPLOADING automatically by IRIDA on creation.
