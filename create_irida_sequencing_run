# create_irida_sequencing_run
# create a new sequencing run in IRIDA
# echo-only: copy and execute the output manually
#
# usage: create_irida_sequencing_run SEQUENCER_TYPE LAYOUT_TYPE [DESCRIPTION] [WORKFLOW]
#
# SEQUENCER_TYPE: free-form string, e.g. miseq, nextseq, miniseq, iseq, nextseq2k
# LAYOUT_TYPE:    PAIRED_END or SINGLE_END
# DESCRIPTION:    optional free-form string
# WORKFLOW:       optional free-form string
#
# example: create_irida_sequencing_run miseq PAIRED_END "Salmonella run 2026-04-08"
