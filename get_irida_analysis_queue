get_irida_analysis_queue() {
    check_bitwarden_serve || { /usr/bin/printf "bw-serve.service not running; start it via\n\tsystemctl --user stop bw-serve.service\n\tsystemctl --user start bw-serve.service\n\t/usr/local/bin/vault_unlock.sh\n" ; return 1 ; }
    check_irida_connectivity || return 1
    local _cookie_jar
    _cookie_jar=$( mktemp /tmp/irida_session.XXXXXX )
    trap "rm -f '${_cookie_jar}'" RETURN
    local BW_URL="http://127.0.0.1:8087"
    local BW_ITEM="772acf18-2e78-44a9-9fb8-b41500c8c864"
    local BW_DATA
    BW_DATA=$( /usr/bin/curl --silent "${BW_URL}/object/item/${BW_ITEM}" )
    [[ $( echo "${BW_DATA}" | /usr/bin/jq -r '.success' ) != "true" ]] && { echo "ERROR: failed to retrieve Bitwarden item ${BW_ITEM}" >&2 ; return 1 ; }
    local _username=$( echo "${BW_DATA}" | /usr/bin/jq -r '.data.login.username' | /usr/bin/tr -d '\r' )
    local _password=$( /usr/bin/urlencode $( echo "${BW_DATA}" | /usr/bin/jq -r '.data.login.password' | /usr/bin/tr -d '\r' ) )
    /usr/bin/curl --silent --cookie-jar "${_cookie_jar}" --cookie "${_cookie_jar}" -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/login" -o /dev/null
    local _login_http_code
    _login_http_code=$( /usr/bin/curl --silent --cookie-jar "${_cookie_jar}" --cookie "${_cookie_jar}" -X POST "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/login" -d "username=${_username}&password=${_password}" -o /dev/null -w '%{http_code}' )
    [[ "${_login_http_code}" != "302" ]] && { echo "ERROR: login failed with HTTP ${_login_http_code}" >&2 ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' --cookie "${_cookie_jar}" "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/ajax/analyses/queue" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) echo "${_response}" | /usr/bin/jq '{running: .running, queued: .queued}' | /usr/bin/mlr --ijson --opprint cat ;;
        302) echo "ERROR: session auth failed - redirected to login" >&2 ; return 1 ;;
        403) echo "ERROR: HTTP 403 - access denied" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

complete get_irida_analysis_queue

# NOTE: this is an undocumented AJAX endpoint, not part of the IRIDA REST API.
# Discovered 2026-05-06 by reading AnalysesTableAjaxController.java in IRIDA source.
# The endpoint calls analysisSubmissionService.getAnalysisServiceStatus() which
# queries the database directly - no Galaxy roundtrip.
# Implementation: analysisSubmissionRepository.countByAnalysisState() for running
# and queued counts. Pure SQL COUNT query, no Galaxy involvement.
# Safe to poll frequently (Jeevan's browser polls it every 60 seconds from the
# analyses page with no issues).
#
# Authorization: @PreAuthorize("hasRole('ROLE_USER')") - any authenticated user.
# No admin credentials required. Confirmed in AnalysisSubmissionServiceImpl.java.
#
# AJAX endpoints do not accept Bearer tokens. Session auth is required:
# 1. GET /login to obtain JSESSIONID cookie
# 2. POST /login with username + password to authenticate the session
# 3. Use the authenticated session cookie for the AJAX call
#
# The login POST returns 302 redirect to / on success.
# The queue endpoint returns {"running": N, "queued": N}.
#
# See also: GET /ajax/analyses/list (paginated analysis table, not yet wrapped)
#           GET /ajax/analyses/types (registered workflow types)
#           GET /ajax/analyses/states (analysis state enum values)
#           GET /ajax/analyses/{id}/updated-table-progress (single analysis progress)
