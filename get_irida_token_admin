# get_irida_token_admin
# get IRIDA OAuth token for admin account and export as IRIDA_TOKEN
# reads credentials from Bitwarden via bw serve (must be running on 127.0.0.1:8087)
#
# example: get_irida_token_admin && echo "token: ${IRIDA_TOKEN}"
#
# WARNING: this exports IRIDA_TOKEN - it will overwrite any existing token.
# use get_irida_token to revert to the non-admin account.
