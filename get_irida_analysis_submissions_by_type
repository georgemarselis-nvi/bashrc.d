get_irida_analysis_submissions_by_type() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} TYPE (phylogenomics|assembly|sistr)" >&2 ; return 1 ; }
    [[ ! "${1}" =~ ^(phylogenomics|assembly|sistr)$ ]] && { echo "ERROR: invalid type: ${1} (phylogenomics|assembly|sistr)" >&2 ; return 1 ; }
    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f mono12 --filter border "WARNING"
    fi
    echo "This endpoint queries Galaxy directly. It is SLOW. expect 15-60 seconds or more."
    echo ""
    local spinner_pid
    local spinstr='|/-\'
    ( while true; do
        for i in 0 1 2 3; do
            printf "\r  querying Galaxy... ${spinstr:$i:1}" > /dev/tty
            sleep 0.2
        done
    done ) 2>/dev/null &
    spinner_pid=$!
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/analysisSubmissions/analysisType/${1}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    kill "${spinner_pid}" 2>/dev/null
    wait "${spinner_pid}" 2>/dev/null
    printf "\r                          \r"
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "no ${1} analyses found" >&2 ; return 1 ; }
             echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, state: .analysisState, cleaned: .analysisCleanedState, priority: .priority, workflow: .workflowId, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: no ${1} analyses found"                  >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -W "phylogenomics assembly sistr" get_irida_analysis_submissions_by_type
# NOTE: IRIDA makes synchronous blocking calls to Galaxy for every analysis submission in the list.
# There is no timeout, no async, and no pagination limit. If Galaxy is slow or busy, IRIDA holds
# the connection open indefinitely. With a large assembly history this can mean hundreds of
# sequential Galaxy API calls before you get a response. The assembly type is the worst offender.
# If the function hangs, kill it with Ctrl+C - Galaxy is not responding to IRIDA.
# This is an IRIDA architectural issue, not a bug in this function.
