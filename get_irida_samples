get_irida_samples() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID (you need the first argument)" ; return 1 ; }
    local http_code
    http_code=$( /usr/bin/curl --silent -o /dev/null -w "%{http_code}" -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${1%%:*}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    [[ "${http_code}" == "404" || "${http_code}" == "403" ]] && { echo "project ${1%%:*} not found or no access" ; return 1 ; }
    local response
    response=$( /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${1%%:*}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    [[ $( echo "${response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "project ${1%%:*} has no samples" ; return 1 ; }
    echo "${response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .sampleName, description: .description, organism: .organism, isolate: .isolate, strain: .strain, collected_by: .collectedBy, collection_date: (if .collectionDate then (if (.collectionDate | type) == "number" then (.collectionDate / 1000 | strftime("%Y-%m-%d")) else .collectionDate end) else null end), location: .geographicLocationName, isolation_source: .isolationSource, latitude: .latitude, longitude: .longitude, created: (if (.createdDate | type) == "number" then (.createdDate / 1000 | strftime("%Y-%m-%d")) else .createdDate end), modified: (if (.modifiedDate | type) == "number" then (.modifiedDate / 1000 | strftime("%Y-%m-%d")) else .modifiedDate end)}]' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_projects_complete get_irida_samples
