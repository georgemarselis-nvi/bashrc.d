get_irida_samples() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID" >&2 ; return 1 ; }
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects/${1%%:*}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "project ${1%%:*} has no samples" ; return 1 ; }
             echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .sampleName, description: .description, organism: .organism, isolate: .isolate, strain: .strain, collected_by: .collectedBy, collection_date: (if .collectionDate then (if (.collectionDate | type) == "number" then (.collectionDate / 1000 | strftime("%Y-%m-%d")) else .collectionDate end) else null end), location: .geographicLocationName, isolation_source: .isolationSource, latitude: .latitude, longitude: .longitude, created: (if (.createdDate | type) == "number" then (.createdDate / 1000 | strftime("%Y-%m-%d")) else .createdDate end), modified: (if (.modifiedDate | type) == "number" then (.modifiedDate / 1000 | strftime("%Y-%m-%d")) else .modifiedDate end)}]' | /usr/bin/mlr --ijson --opprint cat ;;
        403) echo "ERROR: HTTP 403 - project ${1%%:*} access denied" >&2 ; return 1 ;;
        404) echo "ERROR: HTTP 404 - project ${1%%:*} not found" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

complete -F _irida_projects_complete get_irida_samples
