# gets all the samples in a IRIDA project
#
# nothing to tab

get_irida_samples() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    /usr/bin/curl --silent -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/projects/${1%%:*}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .sampleName, organism: .organism, collected_by: .collectedBy}]' | /usr/bin/mlr --ijson --opprint cat ;
}

complete -F _irida_projects_complete get_irida_samples
