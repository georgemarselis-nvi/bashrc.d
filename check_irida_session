check_irida_session() {
    [[ $- == *i* ]] || return 0
    [[ -z "${IRIDA_SESSION_FILE}" || "${IRIDA_SESSION_FILE}" == "null" ]] && { echo "ERROR: IRIDA_SESSION_FILE not set - run get_irida_session" >&2 ; return 1 ; }
    [[ ! -f "${IRIDA_SESSION_FILE}" ]] && { echo "ERROR: session file not found: ${IRIDA_SESSION_FILE} - run get_irida_session" >&2 ; return 1 ; }
    local _http_code
    _http_code=$( /usr/bin/curl --silent --write-out '%{http_code}' -o /dev/null --cookie "${IRIDA_SESSION_FILE}" "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/ajax/projects" )
    case "${_http_code}" in
        200) return 0 ;;
        302) echo "ERROR: session expired or invalid - run get_irida_session" >&2 ; return 1 ;;
        403) echo "ERROR: session valid but access denied to /ajax/projects" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code} checking session" >&2 ; return 1 ;;
    esac
}
