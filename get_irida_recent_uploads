# get_irida_recent_uploads
# list samples created in the last N days across all projects
#
# NOTE: requires an IRIDA admin token - regular user tokens will not return all projects
#
# usage: get_irida_recent_uploads [--since-days N]
#        default: 30 days
#
# example: get_irida_recent_uploads
#          get_irida_recent_uploads --since-days 7
#
