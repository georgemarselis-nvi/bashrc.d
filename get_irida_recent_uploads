# along with this program. If not, see <https://www.gnu.org/licenses/>.
get_irida_recent_uploads() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    local _since_days=30 _http_code _response _tmp
    for _arg in "$@"; do
        case "${_arg}" in
            --since-days) : ;;
            [0-9]*) _since_days="${_arg}" ;;
            *) echo "ERROR: unknown argument: ${_arg}" >&2 ; return 1 ;;
        esac
    done
    local _cutoff_ms=$(( ( $(date +%s) - (_since_days * 86400) ) * 1000 ))
    _tmp=$( mktemp )
    printf 'please wait, fetching projects...\r' >&2
    /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects" -H "Authorization: Bearer ${IRIDA_TOKEN}" > "${_tmp}"
    printf '\r\033[K' >&2
    _http_code=$( /usr/bin/tail -1 "${_tmp}" )
    _response=$( /usr/bin/sed '$d' "${_tmp}" )
    rm -f "${_tmp}"
    case "${_http_code}" in
        200) ;;
        401) echo "ERROR: HTTP 401 - unauthorized" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
    local _rows="" _pid _pname _proj_response _proj_http _tmp2 _new
    local _projects=$( echo "${_response}" | /usr/bin/jq -r '.resource.resources[] | [.identifier, .name] | @tsv' )
    [[ -z "${_projects}" ]] && { echo "ERROR: no projects returned - admin token required" >&2 ; return 1 ; }
    while IFS=$'\t' read -r _pid _pname; do
        _tmp2=$( mktemp )
        printf 'please wait, fetching samples for project %s...\r' "${_pname}" >&2
        /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects/${_pid}/samples" -H "Authorization: Bearer ${IRIDA_TOKEN}" > "${_tmp2}"
        printf '\r\033[K' >&2
        _proj_http=$( /usr/bin/tail -1 "${_tmp2}" )
        _proj_response=$( /usr/bin/sed '$d' "${_tmp2}" )
        rm -f "${_tmp2}"
        if [[ "${_proj_http}" == "200" ]]; then
            _new=$( echo "${_proj_response}" | /usr/bin/jq -r --argjson cutoff "${_cutoff_ms}" --arg pname "${_pname}" '[.resource.resources[] | select(.createdDate >= $cutoff) | {project: $pname, sample: .sampleName, created: (.createdDate / 1000 | strftime("%Y-%m-%d"))}] | .[] | [.project, .sample, .created] | @tsv' )
            [[ -n "${_new}" ]] && _rows+="${_new}"$'\n'
        fi
    done <<< "${_projects}"
    [[ -z "${_rows}" ]] && { echo "no samples created in the last ${_since_days} days" >&2 ; return 0 ; }
    echo "DEBUG rows: ${_rows}" >&2
    printf '%s' "${_rows}" | /usr/bin/sed '/^$/d' | /usr/bin/mlr --itsv --opprint label project,sample,created then sort -f created
}

_get_irida_recent_uploads_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( $(compgen -W '--since-days' -- "${cur}") )
}

complete -F _get_irida_recent_uploads_complete get_irida_recent_uploads
