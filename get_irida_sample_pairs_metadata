# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
# GNU General Public License for more details.
#
# You should have received a copy of the GNU General Public License
# along with this program. If not, see <https://www.gnu.org/licenses/>.
get_irida_sample_pairs_metadata() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID (you need the second argument, as well)" >&2 ; return 1 ; }
    [[ ! "${2%%:*}" =~ ^[0-9]+$ ]] && { echo "ERROR: invalid sample ID: ${2%%:*}" >&2 ; return 1 ; }
    local _sample_id="${2%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/pairs" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "sample ${_sample_id} has no paired files" ; return 1 ; } ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: sample ${_sample_id} not found"         >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"            >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"          >&2 ; return 1 ;;
    esac
    local _pairs _results=()
    _pairs=$( echo "${_response}" | /usr/bin/jq -r '.resource.resources[].identifier' )
    for _pair_id in ${_pairs}; do
        local _pair_response _pair_http_code
        _pair_response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "http://irida.vigasp.vetinst.no:8080/irida-23.01.3/api/samples/${_sample_id}/pairs/${_pair_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
        _pair_http_code=$( echo "${_pair_response}" | /usr/bin/tail -1 )
        _pair_response=$(  echo "${_pair_response}" | /usr/bin/sed '$d' )
        case "${_pair_http_code}" in
            200) _results+=( "$( echo "${_pair_response}" | /usr/bin/jq -c '{id: .resource.identifier, r1: .resource.forwardSequenceFile.fileName, r1_id: .resource.forwardSequenceFile.identifier, r1_size: .resource.forwardSequenceFile.fileSizeBytes, r1_sha256: .resource.forwardSequenceFile.uploadSha256, r2: .resource.reverseSequenceFile.fileName, r2_id: .resource.reverseSequenceFile.identifier, r2_size: .resource.reverseSequenceFile.fileSizeBytes, r2_sha256: .resource.reverseSequenceFile.uploadSha256, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d")), processingState: .resource.processingState}' )" ) ;;
            401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
            403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
            404) echo "ERROR: pair ${_pair_id} not found"             >&2 ; return 1 ;;
            500) echo "ERROR: IRIDA internal server error"            >&2 ; return 1 ;;
            *)   echo "ERROR: unexpected HTTP ${_pair_http_code}"     >&2 ; return 1 ;;
        esac
    done
    printf '%s\n' "${_results[@]}" | /usr/bin/jq -s '.' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_samples_complete get_irida_sample_pairs_metadata
