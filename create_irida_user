create_irida_user() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { /usr/bin/printf "Missing username.\nusage: ${FUNCNAME[0]} USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]\n" ; return 1 ; }
    [[ -z "${2}" ]] && { /usr/bin/printf "Missing first name.\nusage: ${FUNCNAME[0]} USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]\n" ; return 1 ; }
    [[ -z "${3}" ]] && { /usr/bin/printf "Missing last name.\nusage: ${FUNCNAME[0]} USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]\n" ; return 1 ; }
    [[ -z "${4}" ]] && { /usr/bin/printf "Missing email.\nusage: ${FUNCNAME[0]} USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]\n" ; return 1 ; }
    [[ -z "${5}" ]] && { /usr/bin/printf "Missing system role.\nusage: ${FUNCNAME[0]} USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]\n" ; return 1 ; }
    [[ "${5}" != "ROLE_ADMIN" && "${5}" != "ROLE_MANAGER" && "${5}" != "ROLE_USER" && "${5}" != "ROLE_TECHNICIAN" && "${5}" != "ROLE_SEQUENCER" ]] && { echo "invalid systemRole: ${5} (ROLE_ADMIN|ROLE_MANAGER|ROLE_USER|ROLE_TECHNICIAN|ROLE_SEQUENCER)" ; return 1 ; }
    [[ -n "${6}" && ${#6} -lt 4 ]] && { echo "ERROR: phoneNumber must be at least 4 characters" >&2 ; return 1 ; }
    if [[ -x /usr/bin/toilet ]]; then
        /usr/bin/toilet -f term --filter border "Reminder: admin credentials required" >&2
    else
        echo "WARNING: admin credentials required" >&2
    fi
    local _password _password_encoded
    _password=$( /usr/bin/pwgen --capitalize --numerals --symbols --secure --ambiguous 16 1 )
    _password_encoded=$( /usr/bin/urlencode "${_password}" )
    local _http_code _response
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X POST "${IRIDA_BASE_URL}/api/users" -H "Authorization: Bearer ${IRIDA_TOKEN}" -H 'Content-Type: application/json' -d "$( /usr/bin/jq -cn --arg un "${1}" --arg fn "${2}" --arg ln "${3}" --arg em "${4}" --arg sr "${5}" --arg ph "${6:-}" --arg pw "${_password_encoded}" '{"username": $un, "firstName": $fn, "lastName": $ln, "email": $em, "systemRole": $sr, "password": $pw, "locale": "en"} | if $ph != "" then . + {"phoneNumber": $ph} else . end' )" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$( echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        201) echo "${_response}" | /usr/bin/jq '{id: (.resource.identifier | tonumber), username: .resource.username, firstName: .resource.firstName, lastName: .resource.lastName, email: .resource.email, role: .resource.systemRole, created: (.resource.createdDate / 1000 | strftime("%Y-%m-%d"))}' | /usr/bin/mlr --ijson --opprint cat
             echo "password: ${_password}" ;;
        400) echo "ERROR: bad request - $( echo "${_response}" | /usr/bin/jq -r '.message // .' )" >&2 ; return 1 ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden - admin token required" >&2 ; return 1 ;;
        409) echo "ERROR: conflict - username or email already exists" >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error" >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}" >&2 ; return 1 ;;
    esac
}

# tab completion for create_irida_user SYSTEM_ROLE (arg 5)
_irida_create_user_complete() {
    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"
    case ${COMP_CWORD} in
        5)  COMPREPLY=( $(compgen -W "ROLE_ADMIN ROLE_MANAGER ROLE_USER ROLE_TECHNICIAN ROLE_SEQUENCER" -- "${COMP_WORDS[COMP_CWORD]}") ) ;;
        6)  COMPREPLY=( '""' ) ;;
        *)  COMPREPLY=() ;;
    esac
}

complete -F _irida_create_user_complete create_irida_user

# NOTE: POST /api/users returns 403 as non-admin. Admin token required.
# Password is auto-generated via pwgen and printed to stdout in plaintext.
# Operator must communicate the password to the new user securely.
# locale is hardcoded to "en" - NVI standard.
# phoneNumber is optional - omitted from payload if not provided.
