# create_irida_user
# create a new IRIDA user account
# requires admin token - use get_irida_token_admin first
#
# usage: create_irida_user USERNAME FIRSTNAME LASTNAME EMAIL SYSTEM_ROLE [PHONE]
#
# SYSTEM_ROLE: ROLE_ADMIN, ROLE_MANAGER, ROLE_USER, ROLE_TECHNICIAN, ROLE_SEQUENCER
# PASSWORD:    auto-generated via pwgen, printed to stdout
# PHONE:       optional, must be at least 4 characters if provided
#
# example: create_irida_user jdoe John Doe john.doe@vetinst.no ROLE_USER
