# mod_irida_user
# update fields on an existing IRIDA user via PATCH /api/users/{id}
# requires admin token for other users; non-admin can only patch their own user
#
# patchable fields: username, email, password, firstName, lastName, phoneNumber, enabled, systemRole, locale
#
# usage: mod_irida_user USER_ID|USERNAME [--username USERNAME] [--email EMAIL] [--password PASSWORD]
#                                        [--firstname FIRSTNAME] [--lastname LASTNAME] [--phone PHONE]
#                                        [--enabled true|false] [--role ROLE] [--locale LOCALE]
#
# example: mod_irida_user 54:kotop --email newemail@vetinst.no --phone 99887766
# example: mod_irida_user gmarselis --phone 1-800-2600
#
# NOTE: confirmed working as non-admin for own user. 403 for other users. See issue #12.
# NOTE: systemRole values: ROLE_USER | ROLE_ADMIN | ROLE_TECHNICIAN | ROLE_SEQUENCER | ROLE_MANAGER
#
