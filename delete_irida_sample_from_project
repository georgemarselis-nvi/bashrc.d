delete_irida_sample_from_project() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID" >&2 ; return 1 ; }
    [[ -z "${2}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID SAMPLE_ID (missing SAMPLE_ID)" >&2 ; return 1 ; }

    local project_id="${1%%:*}"
    local sample_id="${2%%:*}"

    local response
    local http_code
    response=$( /usr/bin/curl --silent -w "\n%{http_code}" -X DELETE "${IRIDA_BASE_URL}/api/projects/${project_id}/samples/${sample_id}" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    http_code=$( echo "${response}" | tail -1 )
    response=$( echo "${response}" | head -n -1 )
    [[ "${http_code}" == "403" ]] && { echo "ERROR: HTTP 403 — not a member of project ${project_id} or insufficient permissions" >&2 ; return 1 ; }
    [[ "${http_code}" == "404" ]] && { echo "ERROR: HTTP 404 — project ${project_id} or sample ${sample_id} not found" >&2 ; return 1 ; }
    [[ "${http_code}" != "200" ]] && { echo "ERROR: unexpected HTTP ${http_code}" >&2 ; return 1 ; }
    echo "sample ${sample_id} removed from project ${project_id}"
    echo "${response}" | /usr/bin/jq '[.resource | {project_samples: (.links[] | select(.rel == "project/samples") | .href), project: (.links[] | select(.rel == "project") | .href)}]' | /usr/bin/mlr --ijson --opprint cat
}

complete -F _irida_samples_complete delete_irida_sample_from_project

# NOTE: removing a sample from a project does not delete the sample or its sequence
# files from IRIDA storage. the sample still exists and can be re-added to a project.
# to permanently delete sequence files use delete_irida_sequence_file.
