# delete_irida_sample_from_project
# delete a sample from an IRIDA project
#
# usage: delete_irida_sample_from_project PROJECT_ID SAMPLE_ID
#
# WARNING: this is destructive. the sample and all its metadata will be removed
# from the project. sequence files are NOT deleted from IRIDA storage.
#
# example: delete_irida_sample_from_project 154:ZZTEST_API_DO_NOT_USE 11743:ZZTEST_SAMPLE_DO_NOT_USE
