# upload_irida_fastq_pair
# upload a paired-end FASTQ pair to a sample in IRIDA
#
# usage: upload_irida_fastq_pair PROJECT_ID SAMPLE_ID SEQUENCING_RUN_ID R1 R2
#
# NOTE: endpoint is /api/samples/{id}/pairs, not /api/samples/{id}/sequenceFiles/pairs.
# Sequencing run must be in UPLOADING state before calling this function.
# Confirmed working as non-admin on VIGASP 23.01.3. RBAC gap - see GitHub issue #12.
#
# example: upload_irida_fastq_pair 150:test_gmarselis 11745:ZZTEST_SAMPLE_DO_NOT_USE \
#          801:SequencingRun_2026-04-06 /path/to/R1.fastq /path/to/R2.fastq
