get_irida_project_analyses() {
    check_irida_connectivity || return 1
    check_irida_token        || return 1
    [[ -z "${1:-}" ]] && { echo "usage: ${FUNCNAME[0]} PROJECT_ID" >&2 ; return 1 ; }
    local _project_id="${1%%:*}"
    local _response _http_code
    _response=$( /usr/bin/curl --silent --write-out '\n%{http_code}' -X GET "${IRIDA_BASE_URL}/api/projects/${_project_id}/analyses" -H "Authorization: Bearer ${IRIDA_TOKEN}" )
    _http_code=$( echo "${_response}" | /usr/bin/tail -1 )
    _response=$(  echo "${_response}" | /usr/bin/sed '$d' )
    case "${_http_code}" in
        200) [[ $( echo "${_response}" | /usr/bin/jq '.resource.resources | length' ) -eq 0 ]] && { echo "project ${_project_id} has no analyses" ; return 1 ; }
             echo "${_response}" | /usr/bin/jq '[.resource.resources[] | {id: .identifier, name: .name, state: .analysisState, cleaned: .analysisCleanedState, priority: .priority, workflow: .workflowId, created: (.createdDate / 1000 | strftime("%Y-%m-%d")), modified: (.modifiedDate / 1000 | strftime("%Y-%m-%d"))}]' | /usr/bin/mlr --ijson --opprint cat ;;
        401) echo "ERROR: unauthorized - token invalid or expired" >&2 ; return 1 ;;
        403) echo "ERROR: forbidden"                               >&2 ; return 1 ;;
        404) echo "ERROR: project ${_project_id} not found"        >&2 ; return 1 ;;
        500) echo "ERROR: IRIDA internal server error"             >&2 ; return 1 ;;
        *)   echo "ERROR: unexpected HTTP ${_http_code}"           >&2 ; return 1 ;;
    esac
}

complete -F _irida_projects_complete get_irida_project_analyses
# NOTE: analysisType field is NOT present in GET /api/projects/{id}/analyses response.
# It only appears in GET /api/analysisSubmissions/{id}/analysis when state=COMPLETED.
